# ================================================================
# Zamawiarka – konfiguracja środowiska
# Skopiuj ten plik jako .env i uzupełnij wartości
# cp .env.example .env
# ================================================================

# ----- GoPOS API -----
# Dane do aplikacji OAuth2 w panelu GoPOS
GOPOS_CLIENT_ID=twoj_client_id
GOPOS_CLIENT_SECRET=twoj_client_secret

# ID organizacji w GoPOS (widoczne w URL panelu lub w ustawieniach)
GOPOS_ORGANIZATION_ID=twoj_organization_id

# ----- Filtr produktów -----
# Ogranicz widoczne produkty do konkretnej grupy/kategorii (podaj dokładną nazwę z GoPOS)
# Zostaw puste żeby pokazywać wszystkie produkty
GOPOS_ITEM_GROUP=CAŁE ciasta

# ----- Serwer -----
# Port na jakim nasłuchuje aplikacja wewnątrz kontenera
PORT=3000

# Port wystawiany na hoście (jeśli używasz docker-compose)
APP_PORT=3000

# Środowisko: production | development
NODE_ENV=production
